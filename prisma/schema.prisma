generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
    id       Int      @id @default(autoincrement())
    email    String   @unique
    name     String?
    password String
    Tarefas  Tarefa[]
}

model Tarefa {
    id        Int     @id @default(autoincrement())
    titulo    String
    descricao String?
    concluida Boolean @default(false)
    userId    Int
    user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    frequencia  String   @default("DIARIA")
}
